{
  "name": "tasteloop-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit --incremental false --pretty false",
    "lint": "eslint . --max-warnings=0",
    "test": "node --test tests/*.test.mjs",
    "test:links": "node scripts/check-links.mjs",
    "check": "npm run typecheck && npm run lint && npm test"
  },
  "engines": {
    "node": ">=20.9 <25"
  },
  "overrides": {
    "postcss": "$postcss",
    "gray-matter": {
      "js-yaml": "3.15.0"
    }
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/typography": "^0.5.20",
    "@types/three": "^0.185.1",
    "framer-motion": "^11.3.19",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.417.0",
    "mp4-muxer": "^5.2.2",
    "next": "15.5.20",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "three": "^0.185.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.19",
    "eslint": "9.39.5",
    "eslint-config-next": "15.5.20",
    "postcss": "8.5.15",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4"
  }
}
